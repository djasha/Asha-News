# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud AI API Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Perplexity AI API Configuration
PERPLEXITY_API_KEY=y    our_perplexity_api_key_here

# Google Fact Check Tools API Configuration
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key_here

# X.AI (Grok) API Configuration (for social/Twitter features)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-beta

# News API Configuration (for evidence gathering)
NEWS_API_KEY=your_news_api_key_here

# API Configuration
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_SITE_URL=http://localhost:3000

# Optional: Set to 'true' to enable AI bias analysis (requires API key)
ENABLE_AI_ANALYSIS=true

# Server Configuration
PORT=3001
NODE_ENV=development

# Directus (CMS) Proxy Configuration
# The server uses these to securely talk to Directus
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=your_directus_admin_access_token

# Google Analytics Configuration
REACT_APP_GA_MEASUREMENT_ID=your_ga4_measurement_id_here

# Google OAuth Configuration (for production)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
