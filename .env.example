# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud AI API Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Perplexity AI API Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Fact Check Tools API Configuration
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key_here

# X.AI (Grok) API Configuration (for social/Twitter features)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-beta

# News API Configuration (for evidence gathering)
NEWS_API_KEY=your_news_api_key_here

# API Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_SITE_URL=http://localhost:3000
REACT_APP_V1_CORE_ONLY=true
# Optional docs issue tracker URL (used by Wiki "Report Docs Issue" buttons)
# Example: https://github.com/<org>/<repo>/issues/new
REACT_APP_DOCS_ISSUE_URL=

# Optional: Set to 'true' to enable AI bias analysis (requires API key)
ENABLE_AI_ANALYSIS=true

# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase configuration (used when DATABASE_URL is not set)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend auth / bootstrap
JWT_SECRET=replace_with_a_long_random_secret
ADMIN_EMAIL=admin@asha.news
ADMIN_EMAILS=admin@asha.news
ADMIN_PASSWORD=replace_with_secure_admin_password
STRICT_AUTH=true
INTERNAL_API_KEY=replace_with_internal_service_key
MCP_PROXY_API_KEY=replace_with_mcp_proxy_key
LEGACY_DIRECTUS_ROUTES_ENABLED=false

# Conflict operations autonomy (cron + kill-switch controlled feature flags)
ENABLE_CONFLICT_OPS_CRON=true
CONFLICT_OPS_CRON_SCHEDULE=*/20 * * * *
CONFLICT_OPS_SHADOW_MODE=true
CONFLICT_OPS_AGENT_TIMEOUT_MS=45000
CONFLICT_OPS_CYCLE_TIMEOUT_MS=180000
CONFLICT_OPS_STRICT_AUTH=true
CONFLICT_OPS_RUN_TRACK_TTL_MS=21600000
CONFLICT_OPS_RUN_TRACK_MAX=200

# Google Analytics Configuration
REACT_APP_GA_MEASUREMENT_ID=your_ga4_measurement_id_here

# Google OAuth Configuration (for production)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/google/callback
