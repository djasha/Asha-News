{
  "openapi": "3.1.0",
  "info": {
    "title": "Asha News Monitor Ops API",
    "version": "1.0.0",
    "description": "Map-first monitor endpoints for layers, digest, signal fusion, freshness, and analyst briefing."
  },
  "servers": [
    {
      "url": "/api/monitor"
    }
  ],
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "const": false },
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/openapi": {
      "get": {
        "summary": "Get this OpenAPI document",
        "responses": {
          "200": { "description": "OpenAPI JSON" }
        }
      }
    },
    "/layers": {
      "get": {
        "summary": "Get monitor map layers",
        "parameters": [
          { "name": "conflict", "in": "query", "schema": { "type": "string" } },
          { "name": "days", "in": "query", "schema": { "type": "integer" } },
          { "name": "verification", "in": "query", "schema": { "type": "string" } },
          { "name": "source_tier", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Map layer payload" }
        }
      }
    },
    "/news/digest": {
      "get": {
        "summary": "Get ranked monitor news digest",
        "parameters": [
          { "name": "conflict", "in": "query", "schema": { "type": "string" } },
          { "name": "days", "in": "query", "schema": { "type": "integer" } },
          { "name": "verification", "in": "query", "schema": { "type": "string" } },
          { "name": "source_tier", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Digest payload" }
        }
      }
    },
    "/signals/fusion": {
      "get": {
        "summary": "Get fused monitor signals",
        "parameters": [
          { "name": "conflict", "in": "query", "schema": { "type": "string" } },
          { "name": "days", "in": "query", "schema": { "type": "integer" } },
          { "name": "verification", "in": "query", "schema": { "type": "string" } },
          { "name": "source_tier", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "min_signal_events", "in": "query", "schema": { "type": "integer" } },
          { "name": "low_verified_share", "in": "query", "schema": { "type": "number" } },
          { "name": "low_confidence", "in": "query", "schema": { "type": "number" } },
          { "name": "stale_hours", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Signal fusion payload" }
        }
      }
    },
    "/freshness": {
      "get": {
        "summary": "Get monitor freshness state",
        "parameters": [
          { "name": "conflict", "in": "query", "schema": { "type": "string" } },
          { "name": "days", "in": "query", "schema": { "type": "integer" } },
          { "name": "stale_hours", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Freshness payload" }
        }
      }
    },
    "/intel/brief": {
      "get": {
        "summary": "Get analyst intel brief",
        "parameters": [
          { "name": "conflict", "in": "query", "schema": { "type": "string" } },
          { "name": "days", "in": "query", "schema": { "type": "integer" } },
          { "name": "verification", "in": "query", "schema": { "type": "string" } },
          { "name": "source_tier", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "min_signal_events", "in": "query", "schema": { "type": "integer" } },
          { "name": "low_verified_share", "in": "query", "schema": { "type": "number" } },
          { "name": "low_confidence", "in": "query", "schema": { "type": "number" } },
          { "name": "stale_hours", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Intel brief payload" }
        }
      }
    }
  }
}
