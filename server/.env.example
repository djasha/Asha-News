# Development Environment Variables
# Copy this file to .env and add your actual API keys

# Groq API Configuration (Primary AI Provider)
GROQ_API_KEY=your_groq_api_key_here
ENABLE_AI_ANALYSIS=true

# OpenAI API Configuration (Backup)
OPENAI_API_KEY=your_openai_api_key_here

# Google Cloud AI API Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Google Fact Check Tools API Configuration
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key_here

# Perplexity AI API Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# X.AI (Grok) API Configuration (for social/Twitter features)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4-fast-reasoning

# Server Configuration
PORT=3001
NODE_ENV=development

# Database (direct PostgreSQL — replaces Directus CMS)
# For VPS: expose postgres port in docker-compose, then use: postgres://directus:PASSWORD@168.231.111.192:5432/directus
# For local dev: postgres://user:pass@localhost:5432/asha_news
DATABASE_URL=postgres://directus:directus@168.231.111.192:5432/directus

# JWT Configuration
JWT_SECRET=asha-news-jwt-secret-key-2024-secure-token-generation
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# MCP Configuration
MCP_GATEWAY_HOST=127.0.0.1
MCP_GATEWAY_PORT=8811
MCP_GATEWAY_TIMEOUT_MS=15000

# RSS Configuration
RSS_AUTO_IMPORT_TO_CMS=true
RSS_ENABLE_CONTENT_SCRAPING=true

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# FreshRSS Google Reader API (server-side)
FRESHRSS_URL=http://168.231.111.192:8081
FRESHRSS_USER=your_freshrss_username
FRESHRSS_PASSWORD=your_freshrss_password

# Admin Configuration
ADMIN_EMAIL=admin@asha.news
ADMIN_PASSWORD=your_secure_admin_password

# AI Debug Mode (set to 'true' for verbose AI logging)
AI_DEBUG=false

# Ingestion Configuration
ENABLE_INGEST_CRON=false
INGEST_CRON_SCHEDULE=*/30 * * * *
BACKEND_URL=http://localhost:3001
